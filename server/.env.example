# Serial port (Windows: COM3, Linux: /dev/ttyUSB0)
SERIAL_PORT=COM3
SERIAL_BAUD=115200

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google Calendar: use OAuth, NOT an API key. See AUTH.md.
# Run: python tools/google_auth_setup.py (creates token.json)
CREDENTIALS_FILE=credentials.json
TOKEN_FILE=token.json
