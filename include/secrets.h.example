/**
 * secrets.h.example — Copy to include/secrets.h and fill in your values.
 *
 * secrets.h is gitignored. NEVER commit real keys.
 */

#ifndef SECRETS_H
#define SECRETS_H

// WiFi
#define WIFI_SSID       "YOUR_WIFI_SSID"
#define WIFI_PASSWORD   "YOUR_WIFI_PASSWORD"

// OpenAI API
#define OPENAI_API_KEY  "sk-your-openai-api-key"

// Google OAuth2 (from Google Cloud Console)
#define GOOGLE_CLIENT_ID     "your-client-id.apps.googleusercontent.com"
#define GOOGLE_CLIENT_SECRET "your-client-secret"

// If you already have a refresh token from the setup script,
// uncomment and paste it. Otherwise leave blank and set via serial.
// #define GOOGLE_REFRESH_TOKEN "1//your-refresh-token"

#endif
